# ============================================================
# FigBack — Environment Variables
# Copy to .env.local and fill in real values
# ============================================================

# ---- Database (PostgreSQL) ----
# Vercel: add Neon from Marketplace → auto-provisioned
# Local:  createdb figback && use the local connection string
DATABASE_URL=postgresql://user:password@host:5432/figback

# ---- Figma ----
# Generate at: https://www.figma.com/developers/api#access-tokens
# Scopes: file_read, file_comments_read
FIGMA_ACCESS_TOKEN=

# ---- Auth (Google OAuth 2.0) ----
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create project (or select existing)
# 3. Configure OAuth consent screen → Internal (for Workspace) or External
# 4. Create "OAuth 2.0 Client ID" → Web application
# 5. Add authorized redirect URIs:
#    - http://localhost:3000/api/auth/callback/google  (dev)
#    - https://your-app.vercel.app/api/auth/callback/google  (prod)
# 6. Copy Client ID and Client Secret below
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Restrict sign-in to this email domain (leave empty for any domain)
ALLOWED_EMAIL_DOMAIN=symphony.is

# Set to true when behind a reverse proxy (Vercel, Cloudflare, etc.)
AUTH_TRUST_HOST=true

# ---- LLM (set at least one for comment classification) ----
# Google:    https://aistudio.google.com/apikey
# OpenAI:   https://platform.openai.com/api-keys
# Anthropic: https://console.anthropic.com/settings/keys
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- Blob Storage ----
# Vercel: add Blob from dashboard → auto-provisioned
BLOB_READ_WRITE_TOKEN=

# ---- Cron & Security ----
# Generate with: openssl rand -base64 32
CRON_SECRET=
IMAGE_SIGN_SECRET=

# ---- Push Notifications (optional) ----
# Generate VAPID keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Client-side public key (must match VAPID_PUBLIC_KEY)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ---- App URL ----
# Vercel auto-sets VERCEL_URL; override for custom domains
NEXT_PUBLIC_APP_URL=http://localhost:3000

